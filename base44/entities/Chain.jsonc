{
  "name": "Chain",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Chain name"
    },
    "head_store_user_email": {
      "type": "string",
      "description": "Email of the head store owner/admin"
    },
    "description": {
      "type": "string",
      "description": "Chain description"
    }
  },
  "required": [
    "name",
    "head_store_user_email"
  ],
  "rls": {
    "create": {
      "data.head_store_user_email": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "data.head_store_user_email": "{{user.email}}"
        },
        {
          "id": "{{user.chain_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "data.head_store_user_email": "{{user.email}}"
    },
    "delete": {
      "data.head_store_user_email": "{{user.email}}"
    }
  }
}