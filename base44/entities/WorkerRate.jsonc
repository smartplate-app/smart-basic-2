{
  "name": "WorkerRate",
  "type": "object",
  "properties": {
    "worker_id": {
      "type": "string",
      "description": "Worker ID"
    },
    "worker_name": {
      "type": "string",
      "description": "Worker name (for reference)"
    },
    "rate_type": {
      "type": "string",
      "enum": [
        "base_payment",
        "tip_hourly"
      ],
      "default": "base_payment",
      "description": "Type of rate"
    },
    "amount": {
      "type": "number",
      "description": "Rate amount (ILS)"
    },
    "effective_from": {
      "type": "string",
      "format": "date",
      "description": "Start date of this rate"
    },
    "effective_to": {
      "type": "string",
      "format": "date",
      "description": "End date (if ended)"
    },
    "notes": {
      "type": "string",
      "description": "Notes or reason for change"
    }
  },
  "required": [
    "worker_id",
    "rate_type",
    "amount",
    "effective_from"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "data.store_owner_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "data.store_owner_email": "{{user.email}}"
        },
        {
          "data.worker_id": "{{user.data.worker_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "data.store_owner_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "data.store_owner_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}